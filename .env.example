# Safe configuration template for PlanDeck.
# Copy values into your local secret store, user-secrets, Azure Key Vault, or Azure Pipelines variables.
# Do not put real secrets in this file.

ASPNETCORE_ENVIRONMENT=Development

# Microsoft Entra ID authentication
Authentication__Microsoft__TenantId=00000000-0000-0000-0000-000000000000
Authentication__Microsoft__ClientId=00000000-0000-0000-0000-000000000000
Authentication__Microsoft__ClientSecret=replace-in-secret-store
Authentication__Microsoft__CallbackPath=/signin-oidc

# Database
ConnectionStrings__DefaultConnection=Server=localhost,2140;Database=PlanDeckDb;User Id=sa;Password=replace-in-secret-store;TrustServerCertificate=True

# Azure DevOps integration
AzureDevOps__OrganizationUrl=https://dev.azure.com/your-organization
AzureDevOps__Project=your-project
AzureDevOps__EstimateField=Microsoft.VSTS.Scheduling.StoryPoints
AzureDevOps__ClientId=00000000-0000-0000-0000-000000000000
AzureDevOps__ClientSecret=replace-in-secret-store
AzureDevOps__PersonalAccessToken=replace-in-secret-store

# Notifications
EmailSettings__Host=localhost
EmailSettings__Port=1025
EmailSettings__Sender=noreply@example.local
Teams__WebhookUrl=replace-in-secret-store

# Azure deployment
AZURE_SUBSCRIPTION_ID=00000000-0000-0000-0000-000000000000
AZURE_TENANT_ID=00000000-0000-0000-0000-000000000000
AZURE_ENV_NAME=plandeck-dev
AZURE_LOCATION=polandcentral
AZURE_RESOURCE_GROUP=rg-plandeck-dev
