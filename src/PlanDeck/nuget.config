<?xml version="1.0" encoding="utf-8"?>
<!--
  Pin package restore to nuget.org only. The CI/CD pipeline (GitHub-hosted runners) has no access
  to any corporate NuGet mirror, so packages.lock.json content hashes must be generated against
  the same public feed CI uses. Without this, locally generated lock hashes (from an internal
  feed) fail CI restore with NU1403 (content hash validation failed).
-->
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
  </packageSources>
  <packageSourceMapping>
    <clear />
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
  </packageSourceMapping>
</configuration>
