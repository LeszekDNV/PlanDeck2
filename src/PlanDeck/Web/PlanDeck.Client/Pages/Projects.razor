@page "/projects"
@using Grpc.Core
@using PlanDeck.Client.Services
@using PlanDeck.Core.Shared.Contracts
@inject IProjectClientService ProjectService
@inject IStringLocalizer<SharedResource> L
@inject ISnackbar Snackbar
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthState

<PageTitle>@L["Projects_Title"]</PageTitle>

<MudContainer MaxWidth="MaxWidth.False" Class="mt-6 px-4">
    <AuthorizeView>
        <Authorized>
            @if (_isGuest)
            {
                <MudAlert Severity="Severity.Warning">@L["Projects_GuestNoAccess"]</MudAlert>
            }
            else
            {
                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-4">
                    <MudText Typo="Typo.h4">@L["Projects_Title"]</MudText>
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add"
                               OnClick="OpenCreate" data-testid="project-create-open">
                        @L["Projects_Create"]
                    </MudButton>
                </MudStack>

                @if (!string.IsNullOrWhiteSpace(_operationError))
                {
                    <MudAlert Severity="Severity.Error" Class="mb-4" data-testid="project-operation-error">
                        @_operationError
                    </MudAlert>
                }

                @if (_loading)
                {
                    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
                }
                else if (_projects.Count == 0)
                {
                    <MudAlert Severity="Severity.Info">@L["Projects_Empty"]</MudAlert>
                }
                else
                {
                    <MudGrid Spacing="3">
                        @foreach (var project in _projects)
                        {
                            <MudItem xs="12" sm="6" lg="4">
                                <MudCard Class="h-100">
                                    <MudCardHeader>
                                        <CardHeaderContent>
                                            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                                                <MudText Typo="Typo.h6">@project.Name</MudText>
                                                <MudChip T="string" Size="Size.Small">@RoleLabel(project.EffectiveRole)</MudChip>
                                            </MudStack>
                                        </CardHeaderContent>
                                    </MudCardHeader>
                                    <MudCardContent>
                                        @if (!string.IsNullOrWhiteSpace(project.Description))
                                        {
                                            <MudText Typo="Typo.body2">@project.Description</MudText>
                                        }
                                    </MudCardContent>
                                    <MudCardActions>
                                        <MudButton Variant="Variant.Outlined" Color="Color.Primary"
                                                   OnClick="@(() => OpenProject(project.Id))"
                                                   data-testid="project-entry">
                                            @L["Projects_OpenDetails"]
                                        </MudButton>
                                    </MudCardActions>
                                </MudCard>
                            </MudItem>
                        }
                    </MudGrid>
                }

                <MudDialog @bind-Visible="_createOpen">
                    <TitleContent>
                        <MudText Typo="Typo.h6">@L["Projects_Create"]</MudText>
                    </TitleContent>
                    <DialogContent>
                        <MudTextField @bind-Value="_createName" Label="@L["Projects_Name"]" Required="true"
                                      Variant="Variant.Outlined" Class="mb-2" data-testid="project-name-input" />
                        <MudTextField @bind-Value="_createDescription" Label="@L["Projects_Description"]"
                                      Variant="Variant.Outlined" Lines="2" />
                    </DialogContent>
                    <DialogActions>
                        <MudButton OnClick="@(() => _createOpen = false)">@L["Teams_Cancel"]</MudButton>
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" Disabled="_busy"
                                   OnClick="CreateProjectAsync" data-testid="project-create-save">
                            @L["Projects_Save"]
                        </MudButton>
                    </DialogActions>
                </MudDialog>
            }
        </Authorized>
        <NotAuthorized>
            <MudAlert Severity="Severity.Warning" Class="mb-4">@L["Projects_NotAuthorized"]</MudAlert>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Login">
                @L["Auth_Login"]
            </MudButton>
        </NotAuthorized>
    </AuthorizeView>
</MudContainer>
