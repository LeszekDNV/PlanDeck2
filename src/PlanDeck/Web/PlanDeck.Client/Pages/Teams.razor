@page "/teams"
@using Grpc.Core
@using PlanDeck.Client.Services
@using PlanDeck.Core.Shared.Contracts
@using PlanDeck.Core.Shared.Validation
@inject ITeamClientService TeamService
@inject IStringLocalizer<SharedResource> L
@inject ISnackbar Snackbar
@inject IDialogService Dialog
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthState

<PageTitle>@L["Teams_Title"]</PageTitle>

<MudContainer MaxWidth="MaxWidth.Medium" Class="mt-6">
    <AuthorizeView>
        <Authorized>
            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-4">
                <MudText Typo="Typo.h4">@L["Teams_Title"]</MudText>
                <MudButton Variant="Variant.Filled" Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.Add" OnClick="OpenCreate">
                    @L["Teams_Create"]
                </MudButton>
            </MudStack>

            @if (_loading)
            {
                <MudProgressCircular Indeterminate="true" />
            }
            else if (_teams.Count == 0)
            {
                <MudAlert Severity="Severity.Info">@L["Teams_Empty"]</MudAlert>
            }
            else
            {
                <MudPaper Class="pa-2 mb-4">
                    @foreach (var team in _teams)
                    {
                        <MudButton FullWidth="true" Class="justify-start"
                                   Color="@(_selectedTeam?.Id == team.Id ? Color.Primary : Color.Default)"
                                   OnClick="@(() => SelectTeamAsync(team))">
                            @team.Name
                        </MudButton>
                    }
                </MudPaper>
            }

            @if (_selectedTeam is not null)
            {
                <MudCard Class="mt-4">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">@L["Members_Title"] — @_selectedTeam.Name</MudText>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent>
                        <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4" Spacing="2">
                            <MudTextField @bind-Value="_newMemberEmail" Label="@L["Members_AddEmail"]"
                                          Variant="Variant.Outlined" Margin="Margin.Dense" />
                            <MudTextField @bind-Value="_newMemberDisplayName" Label="@L["Members_AddDisplayName"]"
                                          Variant="Variant.Outlined" Margin="Margin.Dense" />
                            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                                       Disabled="_memberSubmitting" OnClick="AddMemberAsync">
                                @L["Members_Add"]
                            </MudButton>
                        </MudStack>

                        @if (_membersLoading)
                        {
                            <MudProgressCircular Indeterminate="true" />
                        }
                        else if (_members.Count == 0)
                        {
                            <MudAlert Severity="Severity.Info">@L["Members_Empty"]</MudAlert>
                        }
                        else
                        {
                            <MudList T="TeamMemberDto">
                                @foreach (var member in _members)
                                {
                                    <MudListItem T="TeamMemberDto">
                                        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                                            <MudText>
                                                @member.Email
                                                @if (!string.IsNullOrWhiteSpace(member.DisplayName))
                                                {
                                                    <span> (@member.DisplayName)</span>
                                                }
                                            </MudText>
                                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error"
                                                           Size="Size.Small" aria-label="@L["Members_Remove"]"
                                                           OnClick="@(() => RemoveMemberAsync(member))" />
                                        </MudStack>
                                    </MudListItem>
                                }
                            </MudList>
                        }
                    </MudCardContent>
                </MudCard>
            }

            <MudDialog @bind-Visible="_createOpen">
                <TitleContent>
                    <MudText Typo="Typo.h6">@L["Teams_Create"]</MudText>
                </TitleContent>
                <DialogContent>
                    <MudTextField @bind-Value="_newTeamName" Label="@L["Teams_Name"]"
                                  Required="true" Variant="Variant.Outlined" Class="mb-3" />
                    <MudTextField @bind-Value="_newTeamDescription" Label="@L["Teams_Description"]"
                                  Lines="3" Variant="Variant.Outlined" />
                </DialogContent>
                <DialogActions>
                    <MudButton OnClick="@(() => _createOpen = false)">@L["Teams_Cancel"]</MudButton>
                    <MudButton Color="Color.Primary" Variant="Variant.Filled"
                               Disabled="_createSubmitting" OnClick="SubmitCreateAsync">
                        @L["Teams_Save"]
                    </MudButton>
                </DialogActions>
            </MudDialog>
        </Authorized>
        <NotAuthorized>
            <MudAlert Severity="Severity.Warning" Class="mb-4">@L["Teams_Title"]</MudAlert>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Login">
                @L["Auth_Login"]
            </MudButton>
        </NotAuthorized>
    </AuthorizeView>
</MudContainer>
